@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shnex: <http://www.w3.org/ns/shacl-node-expr#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <pathValues-simple>
      <pathValues-inverse>
      <pathValues-none>
      <pathValues-withFocusNodeConstant>
      <pathValues-withFocusNodeExpression>
    ) ;
.

ex:TestNode
  rdfs:label "test node" ;
.
ex:OtherNode
  ex:link ex:TestNode ;
.

<pathValues-simple>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a simple path values expression" ;
  mf:action [
    sht:nodeExpr [
      shnex:pathValues rdfs:label ;
    ] ;
    sht:focusNode ex:TestNode ; 
  ] ;
  mf:result ( "test node" ) ;
  mf:status sht:approved ;
.
<pathValues-inverse>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a path values expression with an sh:inversePath" ;
  mf:action [
    sht:nodeExpr [
      shnex:pathValues [
        sh:inversePath ex:link ;
      ]
    ] ;
    sht:focusNode ex:TestNode ;
  ] ;
  mf:result ( ex:OtherNode ) ;
  mf:status sht:approved ;
.
<pathValues-none>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a simple path values expression that returns no values" ;
  mf:action [
    sht:nodeExpr [
      shnex:pathValues ex:unbound ;
    ] ;
    sht:focusNode ex:TestNode ; 
  ] ;
  mf:result ( ) ;
  mf:status sht:approved ;
.
<pathValues-withFocusNodeConstant>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a simple path values expression with an explicit (constant) shnex:focusNode" ;
  mf:action [
    sht:nodeExpr [
      shnex:pathValues rdfs:label ;
      shnex:focusNode ex:TestNode ; 
    ] ;
  ] ;
  mf:result ( "test node" ) ;
  mf:status sht:approved ;
.
<pathValues-withFocusNodeExpression>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a simple path values expression with a shnex:focusNode that is an expression by itself" ;
  mf:action [
    sht:nodeExpr [
      shnex:pathValues rdfs:label ;
      shnex:focusNode [
        shnex:pathValues ex:link ;
      ] ; 
    ] ;
    sht:focusNode ex:OtherNode ;
  ] ;
  mf:result ( "test node" ) ;
  mf:status sht:approved ;
.
