@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shnex: <http://www.w3.org/ns/shacl-node-expr#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <orderBy-integer-list>
      <orderBy-integer-list-desc>
      <orderBy-birthDay>
      <orderBy-height>
    ) ;
.

<orderBy-integer-list>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of an orderBy expression with a simple integer list" ;
  mf:action [
    sht:nodeExpr [
      shnex:nodes ( 8 2 3 ) ;
      shnex:orderBy [
        shnex:var "focusNode" ;
      ] ;
    ] ;
  ] ;
  mf:result ( 2 3 8 ) ;
  mf:status sht:approved ;
.

<orderBy-integer-list-desc>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of an orderBy expression with a simple integer list but in descending order" ;
  mf:action [
    sht:nodeExpr [
      shnex:desc true ;
      shnex:nodes ( 8 2 3 ) ;
      shnex:orderBy [
        shnex:var "focusNode" ;
      ] ;
    ] ;
  ] ;
  mf:result ( 8 3 2 ) ;
  mf:status sht:approved ;
.

<orderBy-birthDay>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of an orderBy expression with a pathValues expression" ;
  mf:action [
    sht:nodeExpr [
      shnex:nodes [
        shnex:instancesOf ex:Person ;
      ] ;
      shnex:orderBy [
        shnex:pathValues ex:birthDay ;
      ] ;
    ] ;
  ] ;
  mf:result ( ex:Person1 ex:Person3 ex:Person2 ) ;
  mf:status sht:approved ;
.

<orderBy-height>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of an orderBy expression with a pathValues expression using incomplete values" ;
  rdfs:comment "In this case Person3 has no value, meaning it will go to the beginning of the results." ;
  mf:action [
    sht:nodeExpr [
      shnex:nodes [
        shnex:instancesOf ex:Person ;
      ] ;
      shnex:orderBy [
        shnex:pathValues ex:height ;
      ] ;
    ] ;
  ] ;
  mf:result ( ex:Person3 ex:Person2 ex:Person1 ) ;
  mf:status sht:approved ;
.

ex:Person1
  a ex:Person ;
  ex:birthDay "1971-07-07"^^xsd:date ;
  ex:height 180.0 ;
.
ex:Person2
  a ex:Person ;
  ex:birthDay "2007-07-11"^^xsd:date ;
  ex:height 169 ;
.
ex:Person3
  a ex:Person ;
  ex:birthDay "2004-08-07"^^xsd:date ;
.
