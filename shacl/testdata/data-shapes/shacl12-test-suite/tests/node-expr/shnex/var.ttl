@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shnex: <http://www.w3.org/ns/shacl-node-expr#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <var-bound>
      <var-focusNode>
      <var-unbound>
    ) ;
.
<var-bound>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a var expression querying a bound variable" ;
  mf:action [
    sht:nodeExpr [
      shnex:var "bound" ;
    ] ;
    sht:scope-bound 4.2 ; 
  ] ;
  mf:result ( 4.2 ) ;
  mf:status sht:approved ;
.
<var-focusNode>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a var expression querying the focus node" ;
  mf:action [
    sht:focusNode ex:Aldi ;
    sht:nodeExpr [
      shnex:var "focusNode" ;
    ] ;
  ] ;
  mf:result ( ex:Aldi ) ;
  mf:status sht:approved ;
.
<var-unbound>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a var expression querying an unbound variable" ;
  mf:action [
    sht:nodeExpr [
      shnex:var "unbound" ;
    ] ;
  ] ;
  mf:result () ;
  mf:status sht:approved ;
.
