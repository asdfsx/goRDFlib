@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shnex: <http://www.w3.org/ns/shacl-node-expr#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <matchAll-empty>
      <matchAll-minInclusive-3-false>
      <matchAll-minInclusive-3-true>
    ) ;
.

<matchAll-empty>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a matchAll expression on empty input" ;
  mf:action [
    sht:nodeExpr [
      shnex:matchAll [] ;
      shnex:nodes [] ;
    ] ;
  ] ;
  mf:result ( true ) ;
  mf:status sht:approved ;
.

<matchAll-minInclusive-3-false>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a matchAll expression on an input list of numbers, using a minInclusive shape" ;
  mf:action [
    sht:nodeExpr [
      shnex:matchAll [
        sh:minInclusive 3 ;
      ] ;
      shnex:nodes ( 4 3 1 5 ) ;
    ] ;
  ] ;
  mf:result ( false ) ;
  mf:status sht:approved ;
.

<matchAll-minInclusive-3-true>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a matchAll expression on an input list of numbers, using a minInclusive shape" ;
  mf:action [
    sht:nodeExpr [
      shnex:matchAll [
        sh:minInclusive 3 ;
      ] ;
      shnex:nodes ( 4 3 5 ) ;
    ] ;
  ] ;
  mf:result ( true ) ;
  mf:status sht:approved ;
.
