@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shnex: <http://www.w3.org/ns/shacl-node-expr#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <distinct-focusNode>
      <distinct-list>
      <distinct-termEquality>
    ) ;
.

<distinct-focusNode>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a distinct expression on just the focus node" ;
  mf:action [
    sht:nodeExpr [
      shnex:distinct [
        shnex:var "focusNode" ;
      ] ;
    ] ;
    sht:focusNode ex:TestNode ;
  ] ;
  mf:result ( ex:TestNode ) ;
  mf:status sht:approved ;
.
<distinct-list>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a distinct expression on a list with three members and one duplicate" ;
  mf:action [
    sht:nodeExpr [
      shnex:distinct ( 4 2 4 ) ;
    ] ;
  ] ;
  mf:result ( 4 2 ) ;
  mf:status sht:approved ;
.
<distinct-termEquality>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of an distinct expression on a list with 3 members and no term-equal duplicate" ;
  rdfs:seeAlso <https://www.w3.org/TR/rdf12-concepts/#dfn-literal-term-equality> ;
  mf:action [
    sht:nodeExpr [
      shnex:distinct ( 4 2 "04"^^xsd:integer ) ;
    ] ;
  ] ;
  mf:result ( 4 2 "04"^^xsd:integer ) ;
  mf:status sht:approved ;
.
