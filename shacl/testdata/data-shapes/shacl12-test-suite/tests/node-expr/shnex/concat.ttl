@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shnex: <http://www.w3.org/ns/shacl-node-expr#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <concat-two-lists>
      <concat-three-constants>
      <concat-nested>
    ) ;
.
<concat-two-lists>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a concat expression that concatenates two lists" ;
  mf:action [
    sht:nodeExpr [
      shnex:concat (
        ( 5 4 3 )
        ( 2 1 )
      )
    ] ;
  ] ;
  mf:result ( 5 4 3 2 1 ) ;
  mf:status sht:approved ;
.
<concat-three-constants>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a concat expression that concatenates 4 constants, including a duplicate" ;
  mf:action [
    sht:nodeExpr [
      shnex:concat (
        4 3 2 3
      )
    ] ;
  ] ;
  mf:result ( 4 3 2 3 ) ;
  mf:status sht:approved ;
.
<concat-nested>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a concat expression that just has a single member that needs to be evaluated" ;
  mf:action [
    sht:nodeExpr [
      shnex:concat (
        [
          shnex:exists []
        ]
      )
    ] ;
  ] ;
  mf:result ( false ) ;
  mf:status sht:approved ;
.
