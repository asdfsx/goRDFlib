@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shnex: <http://www.w3.org/ns/shacl-node-expr#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <sum-empty>
      <sum-list-3-integers>
      <sum-list-3-mixed>
      <sum-totalRevenue>
    ) ;
.

<sum-empty>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a sum expression on an empty list" ;
  rdfs:seeAlso <https://www.w3.org/TR/sparql12-query/#aggSum> ;
  mf:action [
    sht:nodeExpr [
      shnex:sum [] ;
    ] ;
  ] ;
  mf:result ( 0 ) ;
  mf:status sht:approved ;
.

<sum-list-3-integers>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a sum expression on a list with three integers" ;
  mf:action [
    sht:nodeExpr [
      shnex:sum ( 4 5 3 ) ;
    ] ;
  ] ;
  mf:result ( 12 ) ;
  mf:status sht:approved ;
.

<sum-list-3-mixed>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a sum expression on a list with three numbers including a mix of integers and decimals" ;
  mf:action [
    sht:nodeExpr [
      shnex:sum ( 4 5.1 3 ) ;
    ] ;
  ] ;
  mf:result ( 12.1 ) ;
  mf:status sht:approved ;
.

<sum-totalRevenue>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a sum expression similar to the example in the spec" ;
  rdfs:seeAlso <https://www.w3.org/TR/shacl12-node-expr/#SumExpression> ;
  mf:action [
    sht:nodeExpr [
      shnex:sum [
        shnex:flatMap [
          shnex:pathValues ex:revenue ;
        ] ;
        shnex:nodes [
          shnex:pathValues ex:department ;
        ] ;
      ] ;
    ] ;
    sht:focusNode ex:MyCompany ;
  ] ;
  mf:result ( 42.0 ) ;
  mf:status sht:approved ;
.

ex:MyCompany
  ex:department [
    ex:revenue 4.2 ;
  ] ;
  ex:department [
    ex:revenue 37.8 ;
  ] .
