@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shnex: <http://www.w3.org/ns/shacl-node-expr#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <if-then-constant>
      <if-then-else>
      <if-then-no-else>
      <if-then-complex>
    ) ;
.

<if-then-constant>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of an if expression with a simple then result" ;
  mf:action [
    sht:nodeExpr [
      shnex:if true ;
      shnex:then 42 ;
    ] ;
  ] ;
  mf:result ( 42 ) ;
  mf:status sht:approved ;
.
<if-then-else>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of an if expression with a simple else result" ;
  mf:action [
    sht:nodeExpr [
      shnex:if false ;
      shnex:then "yes" ;
      shnex:else "no" ;
    ] ;
  ] ;
  mf:result ( "no" ) ;
  mf:status sht:approved ;
.
<if-then-no-else>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of an if expression evaluating to false but there is no else" ;
  mf:action [
    sht:nodeExpr [
      shnex:if false ;
      shnex:then "yes" ;
    ] ;
  ] ;
  mf:result () ;
  mf:status sht:approved ;
.
<if-then-complex>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of an if expression with complex expressions in if and then" ;
  mf:action [
    sht:nodeExpr [
      shnex:if [
        shnex:exists [
          shnex:pathValues rdfs:label ;
        ] ;
      ] ;
      shnex:then [
        shnex:pathValues rdfs:seeAlso ;
      ] ;
    ] ;
    sht:focusNode ex:TestNode ;
  ] ;
  mf:result ( owl:Nothing ) ;
  mf:status sht:approved ;
.

ex:TestNode
  rdfs:label "test node" ;
  rdfs:seeAlso owl:Nothing ;
.
