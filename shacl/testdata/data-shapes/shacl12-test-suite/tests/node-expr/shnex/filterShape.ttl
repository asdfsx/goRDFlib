@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shnex: <http://www.w3.org/ns/shacl-node-expr#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <filterShape-integers>
      <filterShape-labels>
      <filterShape-unconstrained>
    ) ;
.
<filterShape-integers>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a filter shape expression against a shape that requires xsd:integers" ;
  mf:action [
    sht:nodeExpr [
      shnex:filterShape ex:IntegerShape ;
      shnex:nodes ( 3 2.2 1 ) ;
    ] ;
  ] ;
  mf:result ( 3 1 ) ;
  mf:status sht:approved ;
.

ex:IntegerShape
  a sh:NodeShape ;
  sh:datatype xsd:integer ;
.

<filterShape-labels>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a filter shape expression against a shape that requires rdfs:labels" ;
  mf:action [
    sht:nodeExpr [
      shnex:filterShape ex:LabelsShape ;
      shnex:nodes ( ex:Instance1 ex:Instance2 ex:Instance3 ) ;
    ] ;
  ] ;
  mf:result ( ex:Instance1 ex:Instance2 ) ;
  mf:status sht:approved ;
.

ex:LabelsShape
  a sh:NodeShape ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
  ] ;
.
ex:Instance1 rdfs:label "One" .
ex:Instance2 rdfs:label "Two" .
ex:Instance3 rdfs:seeAlso "None" .

<filterShape-unconstrained>
  rdf:type sht:EvalNodeExpr ;
  rdfs:label "Test of a filter shape expression against a shape that doesn't define any constraints" ;
  mf:action [
    sht:nodeExpr [
      shnex:filterShape ex:EmptyShape ;
      shnex:nodes ( 3 2 1 ) ;
    ] ;
  ] ;
  mf:result ( 3 2 1 ) ;
  mf:status sht:approved ;
.

ex:EmptyShape
  a sh:NodeShape ;
.
