@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:AdultShape
    a sh:NodeShape ;
    sh:targetWhere [
        sh:class ex:Person ;
        sh:property [
            sh:path ex:age ;
            sh:minCount 1 ;
            sh:minInclusive 18 ;
        ]
    ] ;
    sh:property ex:AdultShape-votedFor ;
.
ex:AdultShape-votedFor
    a sh:PropertyShape ;
    sh:path ex:votedFor ;
    sh:class ex:Person ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
.
ex:InvalidResource1
  rdf:type ex:Person ;
  rdfs:label "Invalid resource 1 (in target)" ;
  ex:age 18 ;
.
ex:InvalidResource2
  rdf:type ex:Person ;
  rdfs:label "Invalid resource 2 (not in target)" ;
  ex:age 17 ;
.
ex:ValidResource1
  rdf:type ex:Person ;
  ex:age 19 ;
  ex:votedFor ex:InvalidResource1 ;
.
<>
  rdf:type mf:Manifest ;
  mf:entries (
      <targetWhere-001>
    ) ;
.
<targetWhere-001>
  rdf:type sht:Validate ;
  rdfs:label "Test of sh:targetWhere 001" ;
  mf:action [
      sht:dataGraph <> ;
      sht:shapesGraph <> ;
    ] ;
  mf:result [
      rdf:type sh:ValidationReport ;
      sh:conforms "false"^^xsd:boolean ;
      sh:result [
          rdf:type sh:ValidationResult ;
          sh:focusNode ex:InvalidResource1 ;
          sh:resultPath ex:votedFor ;
          sh:resultSeverity sh:Violation ;
          sh:sourceConstraintComponent sh:MinCountConstraintComponent ;
          sh:sourceShape ex:AdultShape-votedFor ;
        ] ;
    ] ;
  mf:status sht:approved ;
.
